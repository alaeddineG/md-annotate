{
  "name": "md-annotate",
  "version": "2.0.0",
  "description": "Shared markdown review surface between Claude and the human — push, annotate, revise.",
  "type": "module",
  "bin": {
    "md-annotate": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "server/",
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mcp": "esbuild mcp-standalone.js --bundle --platform=node --format=esm --outfile=mcp-bridge.js && node -e \"const f='mcp-bridge.js';let s=require('fs').readFileSync(f,'utf8');s=s.replace(/^#!.*\\n/,'');require('fs').writeFileSync(f,'#!/usr/bin/env node\\n'+s)\"",
    "preview": "vite preview",
    "start": "node bin/cli.js start"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@primer/react": "^38.17.0",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.21.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alaeddineG/md-annotate.git"
  },
  "keywords": [
    "markdown",
    "annotation",
    "review",
    "mcp",
    "claude",
    "model-context-protocol"
  ]
}
